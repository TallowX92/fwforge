{
  "name": "fixedwidth-forge-official",
  "displayName": "FixedWidth Forge: Logistics Data Parser",
  "description": "FixedWidth Forge (FW Forge) enables high-speed previewing and table-based exploration of legacy fixed-width and flat-file formats (COBOL, EDI, ERP/Mainframe exports) directly in VS Code. Simply define a YAML layout file to parse and visualize complex data structures without enterprise bloat.",
  "version": "0.1.6",
  "publisher": "Devotall",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Devotall/fwforge.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Data Science",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "fixed-width",
    "mainframe",
    "COBOL",
    "EDI",
    "AS/400",
    "legacy",
    "logistics",
    "supply-chain",
    "flat-file",
    "data-parser",
    "warehouse",
    "ERP",
    "manifest"
  ],
  "activationEvents": [
    "onCommand:fwforge.preview"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fwforge.preview",
        "title": "FixedWidth Forge: Preview as Table"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "fwforge.preview",
          "when": "resourceExtname == .txt || resourceExtname == .fwf"
        }
      ]
    },
    "configuration": {
      "title": "FixedWidth Forge",
      "properties": {
        "fwforge.cliPath": {
          "type": "string",
          "default": "fwforge",
          "description": "Path to the fwforge CLI executable. Default 'fwforge' assumes it's in PATH."
        }
      }
    }
  }
}
