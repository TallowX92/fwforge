{
  "name": "fixedwidth-forge",
  "displayName": "FixedWidth Forge: Logistics Data Parser",
  "description": "Preview legacy fixed-width data (mainframe/ERP/EDI-850/AS/400/COBOL) as tables. Supports .txt .fwf and custom YAML schemas.",
  "version": "0.1.1",
  "publisher": "Devotall",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Devotall/fwforge.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "activationEvents": [
    "onCommand:fwforge.preview"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fwforge.preview",
        "title": "FW Forge: Preview as Table"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "fwforge.preview",
          "when": "resourceExtname == .txt || resourceExtname == .fwf"
        }
      ]
    },
    "configuration": {
      "title": "FixedWidth Forge",
      "properties": {
        "fwforge.cliPath": {
          "type": "string",
          "default": "fwforge",
          "description": "Path to the fwforge CLI (or just 'fwforge' if in PATH)"
        }
      }
    }
  }
}
